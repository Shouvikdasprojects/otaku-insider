"generator\",\"content\":\"v0.app\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Otaku Insider — Discover, Track & Watch Anime\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"Otaku Insider is your anime discovery hub. Explore trending series, seasonal lineups, top-rated anime by genre, trailers, and episodes — powered by the AniList GraphQL API.\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:image\",\"content\":\"http://localhost:3000/opengraph-image?b11afcff612a52f4\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:image:type\",\"content\":\"image/png\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image:alt\",\"content\":\"Otaku Insider — Your ultimate anime companion\"}],[\"$\",\"meta\",\"11\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"12\",{\"name\":\"twitter:title\",\"content\":\"Otaku Insider — Discover, Track & Watch Anime\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:description\",\"content\":\"Otaku Insider is your anime discovery hub. Explore trending series, seasonal lineups, top-rated anime by genre, trailers, and episodes — powered by the AniList GraphQL API.\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:image\",\"content\":\"http://localhost:3000/opengraph-image?b11afcff612a52f4\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:image:alt\",\"content\":\"Otaku Insider — Your ultimate anime companion\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:image:type\",\"content\":\"image/png\"}],[\"$\",\"meta\",\"17\",{\"name\":\"twitter:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"18\",{\"name\":\"twitter:image:height\",\"content\":\"630\"}],[\"$\",\"link\",\"19\",{\"rel\":\"icon\",\"href\":\"/logo.jpg\"}],[\"$\",\"link\",\"20\",{\"rel\":\"apple-touch-icon\",\"href\":\"/logo.jpg\"}],[\"$\",\"$L22\",\"21\",{}]]\n23:I[63558,[\"8500\",\"static/chunks/8500-f62a38ff68ab7f42.js\",\"3701\",\"static/chunks/3701-6812bfea6c6735fd.js\",\"8974\",\"static/chunks/app/page-c954879a0a7cb010.js\"],\"HeroSection\"]\n24:T644,Gold Roger was known as the Pirate King, the strongest and most infamous being to have sailed the Grand Line. The capture and death of Roger by the World Government brought a change throughout the world. His last words before his death revealed the location of the greatest treasure in the world, One Piece. It was this revelation that brought about the Grand Age of Pirates, men who dreamed of finding One Piece (which promises an unlimited amount of riches and fame), and quite possibly the most coveted of titles for the person who found it, the title of the Pirate King.<br><br>\nEnter Monkey D. Luffy, a 17-year-old boy that defies your standard definition of a pirate. Rather than the popular persona of a wicked, hardened, toothless pirate who ransacks villages for fun, Luffy’s reason for being a pirate is one of pure wonder; the thought of an exciting adventure and meeting new and intriguing people, along with finding One Piece, are his reasons of becoming a pirate. Following in the footsteps of his childhood hero, Luffy and his crew travel across the Grand Line, experiencing crazy adventures, unveiling dark mysteries and battling strong enemies, all in order to reach One Piece.<br><br>\n<b>*This includes the following special episodes:</b><br>\n- Chopperman to the Rescue! Protect the TV Station by the Shore! (Episode 336)<br>\n- The Strongest Tag-Team! Luffy and Toriko's Hard Struggle! (Episode 492)<br>\n- Team Formation! Save Chopper (Episode 542)<br>\n- History's Strongest Collaboration vs. Glutton of the Sea (Episode 590)<br>\n- 20th Anniversary! Special Romance Dawn (Episode 907)1b:[[\"$\",\"$L23\",null,{\"items\":[{\"id\":21,\"title\":{\"romaji\":\"ONE PIECE\",\"english\":\"ONE PIECE\",\"native\":\"ONE PIECE\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21-ELSYx3yMPcKM.jpg\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx21-ELSYx3yMPcKM.jpg\",\"color\":\"#e49335\"},\"bannerImage\":\"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21-wf37VakJmZqs.jpg\",\"description\":\"$24\",\"averageScore\":87,\"popularity\":728608,\"episodes\":null,\"duration\":24,\"genres\":[\"Action\",\"Adventure\",\"Comedy\",\"Drama\",\"Fantasy\"],\"format\":\"TV\",\"season\":\"FALL\",\"seasonYear\":1999,\"status\":\"RELEASING\",\"nextAiringEpisode\":{\"episode\":1170,\"airingAt\":1784470560},\"trailer\":null},{\"id\":178789,\"title\":{\"romaji\":\"Mushoku Tensei III: Isekai Ittara Honki Dasu\",\"english\":\"Mushoku Tensei: Jobless Reincarnation Season 3\",\"native\":\"無職転生Ⅲ ～異世界行ったら本気だす～\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx178789-hNXjKFzUq7mk.jpg\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx178789-hNXjKFzUq7mk.jpg\",\"color\":\"#28bbe4\"},\"bannerImage\":\"https://s4.anilist.co/file/anilistcdn/media/anime/banner/178789-9nHWmoRLlcLu.jpg\",\"description\":\"The third season of <i>Mushoku Tensei: Isekai Ittara Honki Dasu</i>.\",\"averageScore\":86,\"popularity\":120113,\"episodes\":14,\"duration\":24,\"genres\":[\"Adventure\",\"Drama\",\"Ecchi\",\"Fantasy\"],\"format\":\"TV\",\"season\":\"SUMMER\",\"seasonYear\":2026,\"status\":\"RELEASING\",\"nextAiringEpisode\":{\"episode\":4,\"airingAt\":1784473200},\"trailer\":{\"id\":\"ODxfIvSgWuo\",\"site\":\"youtube\",\"thumbnail\":\"https://i.ytimg.com/vi/ODxfIvSgWuo/hqdefault.jpg\"}},{\"id\":128757,\"title\":{\"romaji\":\"Tai-Ari deshita.: Ojou-sama wa Kakutou Game nante Shinai\",\"english\":\"Young Ladies Don't Play Fighting Games\",\"native\":\"対ありでした。 ～お嬢さまは格闘ゲームなんてしない～\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx128757-Iqc6hTjEYIz4.png\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx128757-Iqc6hTjEYIz4.png\",\"color\":\"#436bff\"},\"bannerImage\":null,\"description\":\"Mitsuki Aya has one goal at the elite Kuromi Girls’ Academy: to become a refined young lady like the school’s flawless “White Lily,” Yorue Mio. But her image of Mio shatters when Aya accidentally catches her...playing fighting games?! Turns out, the elegant Mio is actually a hardcore gamer—and she wants to duel Aya! The battle (and their friendship) begins.\\n<br><br>\\n(Source: Crunchyroll)\",\"averageScore\":72,\"popularity\":19163,\"episodes\":null,\"duration\":24,\"genres\":[\"Drama\"],\"format\":\"TV\",\"season\":\"SUMMER\",\"seasonYear\":2026,\"status\":\"RELEASING\",\"nextAiringEpisode\":{\"episode\":3,\"airingAt\":1784633400},\"trailer\":{\"id\":\"5PAsOIcot7I\",\"site\":\"youtube\",\"thumbnail\":\"https://i.ytimg.com/vi/5PAsOIcot7I/hqdefault.jpg\"}},{\"id\":169583,\"title\":{\"romaji\":\"Tenkousaki no Seiso Karen na Bishoujo ga, Mukashi Danshi to Omotte Issho ni Asonda Osananajimi datta Ken\",\"english\":\"Oh Boy, Was I Wrong About Her\",\"native\":\"転校先の清楚可憐な美少女が、昔男子と思って一緒に遊んだ幼馴染だった件\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx169583-0ZTdBGrKNIbe.jpg\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx169583-0ZTdBGrKNIbe.jpg\",\"color\":\"#50c9fe\"},\"bannerImage\":null,\"description\":\"Seven years after making a childhood promise to always be friends, Hayato is reunited with his formerly tomboyish pal Haruki at a city high school–only now, Haruki has transformed into the girl every guy dreams about! While Haruki’s looks may have changed, with Hayato, she’s still the same pal he remembers. Despite years apart, their promise and feelings remain and deepen into something stronger.\\n<br><br>\\n(Source: Crunchyroll)\",\"averageScore\":70,\"popularity\":21662,\"episodes\":12,\"duration\":24,\"genres\":[\"Comedy\",\"Romance\"],\"format\":\"TV\",\"season\":\"SUMMER\",\"seasonYear\":2026,\"status\":\"RELEASING\",\"nextAiringEpisode\":{\"episode\":3,\"airingAt\":1784557800},\"trailer\":{\"id\":\"UTsFnJgDJz8\",\"site\":\"youtube\",\"thumbnail\":\"https://i.ytimg.com/vi/UTsFnJgDJz8/hqdefault.jpg\"}},{\"id\":185542,\"title\":{\"romaji\":\"Gaikotsu Kishi-sama, Tadaima Isekai e Odekakechuu II\",\"english\":\"Skeleton Knight in Another World Season 2\",\"native\":\"骸骨騎士様、只今異世界へお出掛け中Ⅱ\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185542-6a9LCWlLHa0T.jpg\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185542-6a9LCWlLHa0T.jpg\",\"color\":\"#286bbb\"},\"bannerImage\":null,\"description\":\"The second season of <i>Gaikotsu Kishi-sama, Tadaima Isekai e Odekakechuu</i>.\",\"averageScore\":69,\"popularity\":35406,\"episodes\":12,\"duration\":24,\"genres\":[\"Action\",\"Adventure\",\"Comedy\",\"Fantasy\"],\"format\":\"TV\",\"season\":\"SUMMER\",\"seasonYear\":2026,\"status\":\"RELEASING\",\"nextAiringEpisode\":{\"episode\":3,\"airingAt\":1784552400},\"trailer\":{\"id\":\"Enu3fyOdkoM\",\"site\":\"youtube\",\"thumbnail\":\"https://i.ytimg.com/vi/Enu3fyOdkoM/hqdefault.jpg\"}},{\"id\":199111,\"title\":{\"romaji\":\"Grand Blue Season 3\",\"english\":\"Grand Blue Dreaming Season 3\",\"native\":\"ぐらんぶる Season 3\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx199111-gBSuBG61ElcW.jpg\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx199111-gBSuBG61ElcW.jpg\",\"color\":\"#5daed6\"},\"bannerImage\":\"https://s4.anilist.co/file/anilistcdn/media/anime/banner/199111-Z8y9awn2Zb6v.jpg\",\"description\":\"The third season of <i>Grand Blue</i>.\",\"averageScore\":82,\"popularity\":30770,\"episodes\":12,\"duration\":24,\"genres\":[\"Comedy\",\"Slice of Life\",\"Sports\"],\"format\":\"TV\",\"season\":\"SUMMER\",\"seasonYear\":2026,\"status\":\"RELEASING\",\"nextAiringEpisode\":{\"episode\":3,\"airingAt\":1784559600},\"trailer\":{\"id\":\"KJw6ZZaMOWA\",\"site\":\"youtube\",\"thumbnail\":\"https://i.ytimg.com/vi/KJw6ZZaMOWA/hqdefault.jpg\"}},{\"id\":202269,\"title\":{\"romaji\":\"Toumei na Yoru ni Kakeru Kimi to, Me ni Mienai Koi wo Shita.\",\"english\":\"Love Unseen Beneath the Clear Night Sky\",\"native\":\"透明な夜に駆ける君と、目に見えない恋をした。\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx202269-7KNj8s2fSsJJ.jpg\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx202269-7KNj8s2fSsJJ.jpg\",\"color\":\"#5da1e4\"},\"bannerImage\":null,\"description\":\"On an April night in Tokyo, still too early for fireworks, university student Kakeru Sorano meets a woman named Koharu Fuyutsuki. She is a beautiful girl who stands out from the crowd, laughs a lot, and exudes a warmth that contrasts sharply with Kakeru's own introversion. But there was something Kakeru didn't know at first—she can't see.<br>\\n<br>\\nUnlike Kakeru, Koharu hasn't given up on anything, even with her blindness. She attends university daily, shows interest in clubs, makes friends—and dreams of launching fireworks one day. Kakeru wonders why, when she can't see them...but maybe it doesn't matter. And maybe he can start moving forward, too, for the girl who's always been by his side<br>\\n<br>\\n(Source: Yen Press)\",\"averageScore\":76,\"popularity\":23693,\"episodes\":null,\"duration\":24,\"genres\":[\"Drama\",\"Romance\"],\"format\":\"TV\",\"season\":\"SUMMER\",\"seasonYear\":2026,\"status\":\"RELEASING\",\"nextAiringEpisode\":{\"episode\":3,\"airingAt\":1784548800},\"trailer\":{\"id\":\"OPZ7TOGxWqI\",\"site\":\"youtube\",\"thumbnail\":\"https://i.ytimg.com/vi/OPZ7TOGxWqI/hqdefault.jpg\"}},{\"id\":182205,\"title\":{\"romaji\":\"Tensei Shitara Slime Datta Ken 4th Season\",\"english\":\"That Time I Got Reincarnated as a Slime Season 4\",\"native\":\"転生したらスライムだった件 第4期\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182205-q2AeO1owuQbO.jpg\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182205-q2AeO1owuQbO.jpg\",\"color\":\"#1abbd6\"},\"bannerImage\":\"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182205-fRUoKv6f2JAq.jpg\",\"description\":\"The fourth season of <i>Tensei Shitara Slime Datta Ken</i>.<br><br>\\nDemon Lord Rimuru's dream of creating an alliance between humans and monsters takes a step closer to being realized. As Tempest continues to prosper, Granville Rozzo and his granddaughter, Maribel Rozzo, clash with Demon Lord Rimuru over their plan to protect mankind by ruling over them. Meanwhile, in El Dorado, Demon Lord Leon works toward goals of his own. The awakening of a new Hero draws near!<br><br>\\n\\n(Source: Crunchyroll News)\",\"averageScore\":82,\"popularity\":115039,\"episodes\":null,\"duration\":24,\"genres\":[\"Action\",\"Adventure\",\"Comedy\",\"Fantasy\"],\"format\":\"TV\",\"season\":\"SPRING\",\"seasonYear\":2026,\"status\":\"RELEASING\",\"nextAiringEpisode\":{\"episode\":15,\"airingAt\":1784296800},\"trailer\":{\"id\":\"ikxIrDr72iA\",\"site\":\"youtube\",\"thumbnail\":\"https://i.ytimg.com/vi/ikxIrDr72iA/hqdefault.jpg\"}},{\"id\":269,\"title\":{\"romaji\":\"BLEACH\",\"english\":\"Bleach\",\"native\":\"BLEACH\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx269-d2GmRkJbMopq.png\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx269-d2GmRkJbMopq.png\",\"color\":\"#f1a150\"},\"bannerImage\":\"https://s4.anilist.co/file/anilistcdn/media/anime/banner/269-08ar2HJOUAuL.jpg\",\"description\":\"Ichigo Kurosaki is a rather normal high school student apart from the fact he has the ability to see ghosts. This ability never impacted his life in a major way until the day he encounters the Shinigami Kuchiki Rukia, who saves him and his family's lives from a Hollow, a corrupt spirit that devours human souls. \\n<br><br>\\nWounded during the fight against the Hollow, Rukia chooses the only option available to defeat the monster and passes her Shinigami powers to Ichigo. Now forced to act as a substitute until Rukia recovers, Ichigo hunts down the Hollows that plague his town. \\n\\n\\n\",\"averageScore\":79,\"popularity\":500544,\"episodes\":366,\"duration\":24,\"genres\":[\"Action\",\"Adventure\",\"Supernatural\"],\"format\":\"TV\",\"season\":\"FALL\",\"seasonYear\":2004,\"status\":\"FINISHED\",\"nextAiringEpisode\":null,\"trailer\":{\"id\":\"0c4IoCA5fY0\",\"site\":\"youtube\",\"thumbnail\":\"https://i.ytimg.com/vi/0c4IoCA5fY0/hqdefault.jpg\"}},{\"id\":195600,\"title\":{\"romaji\":\"Yomi no Tsugai\",\"english\":\"Daemons of the Shadow Realm\",\"native\":\"黄泉のツガイ\"},\"coverImage\":{\"extraLarge\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx195600-moI0UFArtOme.jpg\",\"large\":\"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx195600-moI0UFArtOme.jpg\",\"color\":\"#e49335\"},\"bannerImage\":\"https://s4.anilist.co/file/anilistcdn/media/anime/banner/195600-UxHvDXwzJxlP.jpg\",\"description\":\"In a remote mountain village under the watchful eyes of two stone guardians, the young Yuru contentedly lives off the land while staying close to the only family he has left—Asa, his precious twin sister. Asa, meanwhile, carries out a mysterious “duty” on behalf of the village while locked in a cage. Why is Asa a prisoner? And what other secrets does Yuru’s otherwise idyllic home hide?\\n<br><br>(Source: Square Enix)\",\"averageScore\":78,\"popularity\":117983,\"episodes\":24,\"duration\":24,\"genres\":[\"Action\",\"Adventure\",\"Comedy\",\"Fantasy\",\"Supernatural\"],\"format\":\"TV\",\"season\":\"SPRING\",\"seasonYear\":2026,\"status\":\"RELEASING\",\"nextAiringEpisode\":{\"episode\":15,\"airingAt\":1784385000},\"trailer\":{\"id\":\"XCyj9KKKjUI\",\"site\":\"youtube\",\"thumbnail\":\"https://i.ytimg.com/vi/XCyj9KKKjUI/hqdefault.jpg\"}}]}],\"$L25\",\"$L26\",\